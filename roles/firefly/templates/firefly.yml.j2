services:
  app:
    image: fireflyiii/core:latest
    hostname: app
    container_name: firefly_iii_core
    networks:
      - firefly_iii
    restart: always
    volumes:
      - "{{ docker_container_data_folder }}/firefly/upload:/var/www/html/storage/upload"
    env_file: .env
    ports:
      - '8090:8080'
    depends_on:
      - db

  db:
    image: mariadb:lts
    hostname: db
    container_name: firefly_iii_db
    networks:
      - firefly_iii
    restart: always
    env_file: .db.env
    volumes:
      - {{ docker_container_data_folder }}/firefly/db:/var/lib/mysql

  importer:
    image: fireflyiii/data-importer:latest
    hostname: importer
    restart: always
    container_name: firefly_iii_importer
    networks:
      - firefly_iii
    ports:
      - '81:8080'
    depends_on:
      - app
    env_file: .importer.env

  cron:
    image: alpine
    container_name: firefly_iii_cron
    restart: always
    env_file: .env
    command: >
      sh -c "
        apk add --no-cache tzdata wget &&
        (ln -sf /usr/share/zoneinfo/$$TZ /etc/localtime || true) &&
        echo '0 3 * * * wget -qO- http://app:8080/api/v1/cron/$$STATIC_CRON_TOKEN; echo' > /tmp/crontab_tmp &&
        echo \"40 2 * * * wget -qO - --post-data '' --header 'Accept: application/json' 'http://importer:8080/autoimport?directory=/import&secret=$$AUTO_IMPORT_SECRET'\" >> /tmp/crontab_tmp &&
        crontab /tmp/crontab_tmp &&
        rm /tmp/crontab_tmp &&
        crond -f -L /dev/stdout
      "
    networks:
      - firefly_iii
    depends_on:
      - app
      - importer

  toolbox-for-firefly-iii:
    image: ghcr.io/xenolphthalein/toolbox-for-firefly-iii:latest
    container_name: toolbox-for-firefly-iii
    restart: unless-stopped
    ports:
      - "3000:3000"
    env_file: .toolbox.env
    networks:
      - firefly_iii
    healthcheck:
      test: ["CMD", "wget", "--no-verbose", "--tries=1", "--spider", "http://localhost:3000/api/health"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 10s
    depends_on:
      - app

networks:
  firefly_iii:
    driver: bridge
